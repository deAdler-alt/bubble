# ── Groq (free tier — https://console.groq.com/keys) ──
# Wymagany do /api/transcribe (Whisper) i opcjonalnie /api/songs (Llama).
# Bez tego: /api/transcribe zwróci 503, /api/songs użyje szablonu lyrics.
GROQ_API_KEY=

# Provider tekstów piosenek: "groq" (Llama-3.3) | "template" (deterministyczne szablony).
# Default: groq (gdy GROQ_API_KEY ustawione).
LYRICS_PROVIDER=groq

# Modele (możesz nadpisać jeśli Groq zmieni katalog).
GROQ_WHISPER_MODEL=whisper-large-v3-turbo
GROQ_LLAMA_MODEL=llama-3.3-70b-versatile

# ── Server ──
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info
LOG_PRETTY=0
